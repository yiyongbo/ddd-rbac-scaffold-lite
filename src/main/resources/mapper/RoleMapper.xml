<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.yiyongbo.scaffold.infrastructure.persistence.role.mapper.RoleMapper">

    <select id="listUserIdsByMenuId" resultType="java.lang.Long">
        SELECT *
        FROM sys_role_menu AS rm
        JOIN sys_user_role AS ur ON ur.role_id = rm.role_id
        WHERE rm.menu_id = #{menuId}
    </select>
</mapper>